                <texturefocus colordiffuse="FF4EA1E7">white.png</texturefocus>
                <texturenofocus colordiffuse="33FFFFFF">white.png</texturenofocus>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <disabledcolor>44FFFFFF</disabledcolor>
            </control>
            <control type="button" id="3004">
                <width>235</width>
                <height>80</height>
                <font>font13</font>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(btn_close)]</label>
                <texturefocus colordiffuse="FF4EA1E7">white.png</texturefocus>
                <texturenofocus colordiffuse="33FFFFFF">white.png</texturenofocus>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <disabledcolor>44FFFFFF</disabledcolor>
            </control>
