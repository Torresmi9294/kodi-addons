<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.video.kronos.example" name="Kronos Example" version="1.0.0" provider-name="kronos">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Example addon for testing repo updates</summary>
    <description lang="en_GB">A minimal example addon used to verify the Kronos Kodi repository install and auto-update pipeline. Bump the version and push to see it update on a real device.</description>
    <platform>all</platform>
    <license>MIT</license>
  </extension>
</addon>
<addon id="repository.kronos" name="Kronos Kodi Addons" version="1.0.0" provider-name="kronos">
  <extension point="xbmc.addon.repository" name="Kronos Kodi Addons">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/Torresmi9294/kodi-addons/main/zips/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/Torresmi9294/kodi-addons/main/zips/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/Torresmi9294/kodi-addons/main/zips</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Kronos's personal Kodi addon repository</summary>
    <description lang="en_GB">Repository for testing and distributing custom Kodi addons pushed from GitHub.</description>
    <platform>all</platform>
  </extension>
</addon>
</addons>
