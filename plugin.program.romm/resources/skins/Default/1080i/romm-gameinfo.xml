<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">3001</defaultcontrol>
    <controls>
        <control type="image">
            <description>Fanart background</description>
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <aspectratio>scale</aspectratio>
            <texture background="true">$INFO[Window.Property(fanart)]</texture>
        </control>
        <control type="image">
            <description>Dim overlay</description>
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="E4000000">white.png</texture>
        </control>

        <control type="label">
            <description>Title</description>
            <posx>0</posx>
            <posy>60</posy>
            <width>1920</width>
            <height>60</height>
            <align>center</align>
            <font>font30</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[Window.Property(title)]</label>
        </control>
        <control type="label">
            <description>Platform subtitle</description>
            <posx>0</posx>
            <posy>128</posy>
            <width>1920</width>
            <height>40</height>
            <align>center</align>
            <font>font13</font>
            <textcolor>99FFFFFF</textcolor>
            <label>$INFO[Window.Property(platform)]</label>
        </control>

        <control type="image">
            <description>Cover</description>
            <posx>140</posx>
            <posy>240</posy>
            <width>440</width>
            <height>560</height>
            <aspectratio aligny="top">keep</aspectratio>
            <texture background="true">$INFO[Window.Property(cover)]</texture>
        </control>

        <control type="image">
            <description>Summary panel back</description>
            <posx>640</posx>
            <posy>240</posy>
            <width>760</width>
            <height>560</height>
            <texture colordiffuse="66000000">white.png</texture>
        </control>
        <control type="textbox">
            <description>Summary</description>
            <posx>665</posx>
            <posy>265</posy>
            <width>710</width>
            <height>510</height>
            <font>font13</font>
            <textcolor>EEFFFFFF</textcolor>
            <autoscroll delay="8000" time="4000" repeat="10000">true</autoscroll>
            <label>$INFO[Window.Property(summary)]</label>
        </control>

        <control type="image">
            <description>Meta panel back</description>
            <posx>1430</posx>
            <posy>240</posy>
            <width>360</width>
            <height>560</height>
            <texture colordiffuse="66000000">white.png</texture>
        </control>
        <control type="grouplist">
            <posx>1455</posx>
            <posy>265</posy>
            <width>310</width>
            <height>510</height>
            <orientation>vertical</orientation>
            <itemgap>14</itemgap>
            <control type="label">
                <width>310</width>
                <height>34</height>
                <font>font13</font>
                <textcolor>FF62BEFE</textcolor>
                <label>$INFO[Window.Property(meta1)]</label>
                <visible>!String.IsEmpty(Window.Property(meta1))</visible>
            </control>
            <control type="label">
                <width>310</width>
                <height>34</height>
                <font>font13</font>
                <textcolor>EEFFFFFF</textcolor>
                <label>$INFO[Window.Property(meta2)]</label>
                <visible>!String.IsEmpty(Window.Property(meta2))</visible>
            </control>
            <control type="label">
                <width>310</width>
                <height>34</height>
                <font>font13</font>
                <textcolor>EEFFFFFF</textcolor>
                <label>$INFO[Window.Property(meta3)]</label>
                <visible>!String.IsEmpty(Window.Property(meta3))</visible>
            </control>
            <control type="label">
                <width>310</width>
                <height>34</height>
                <font>font13</font>
                <textcolor>EEFFFFFF</textcolor>
                <label>$INFO[Window.Property(meta4)]</label>
                <visible>!String.IsEmpty(Window.Property(meta4))</visible>
            </control>
            <control type="label">
                <width>310</width>
                <height>34</height>
                <font>font13</font>
                <textcolor>EEFFFFFF</textcolor>
                <label>$INFO[Window.Property(meta5)]</label>
                <visible>!String.IsEmpty(Window.Property(meta5))</visible>
            </control>
            <control type="label">
                <width>310</width>
                <height>34</height>
                <font>font13</font>
                <textcolor>EEFFFFFF</textcolor>
                <label>$INFO[Window.Property(meta6)]</label>
                <visible>!String.IsEmpty(Window.Property(meta6))</visible>
            </control>
        </control>

        <control type="grouplist" id="3000">
            <description>Buttons</description>
            <posx>460</posx>
            <posy>880</posy>
            <width>1000</width>
            <height>90</height>
            <orientation>horizontal</orientation>
            <itemgap>20</itemgap>
            <align>center</align>
            <control type="button" id="3001">
                <width>235</width>
                <height>80</height>
                <font>font13</font>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[Window.Property(btn_launch)]</label>
                <texturefocus colordiffuse="FF4EA1E7">white.png</texturefocus>
                <texturenofocus colordiffuse="33FFFFFF">white.png</texturenofocus>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <disabledcolor>44FFFFFF</disabledcolor>
            </control>
            <control type="button" id="3002">
                <width>235</width>
                <height>80</height>
                <font>font13</font>
                <align>center</align>
                <aligny>center</aligny>
