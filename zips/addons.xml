<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.program.romm" name="RomM Game Launcher" version="1.0.0" provider-name="kronos">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>executable game</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Browse, download, and launch games from your RomM server</summary>
        <description lang="en_GB">The RomM Game Launcher browses your self-hosted RomM (https://romm.app) ROM library from Kodi. Pick a platform, pick a game, and it downloads the ROM from your server and hands it to RetroPlayer (or whatever game addon you have configured). Modeled on the menu structure of the Internet Archive Game Launcher (IAGL), but backed by your own RomM server instead of archive.org.</description>
        <platform>all</platform>
        <license>MIT</license>
        <source>https://github.com/Torresmi9294/kodi-addons</source>
        <assets>
            <icon>resources/icon.png</icon>
        </assets>
    </extension>
</addon>
<addon id="plugin.program.romm.experimental" name="RomM Game Launcher (Experimental)" version="1.4.2" provider-name="kronos">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>executable game</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Experimental testing build of the RomM Game Launcher — not for daily use.</summary>
        <description lang="en_GB">Experimental build of the RomM Game Launcher used to test in-progress changes on a real device before they're promoted into the main addon. Installs side by side with the main addon since it uses a separate addon id. May be unstable.</description>
        <platform>all</platform>
        <license>MIT</license>
        <source>https://github.com/Torresmi9294/kodi-addons</source>
        <assets>
            <icon>resources/icon.png</icon>
        </assets>
    </extension>
</addon>
<addon id="plugin.video.kronos.example" name="Kronos Example" version="1.0.0" provider-name="kronos">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Example addon for testing repo updates</summary>
    <description lang="en_GB">A minimal example addon used to verify the Kronos Kodi repository install and auto-update pipeline. Bump the version and push to see it update on a real device.</description>
    <platform>all</platform>
    <license>MIT</license>
  </extension>
</addon>
<addon id="repository.kronos" name="Kronos Kodi Addons" version="1.0.0" provider-name="kronos">
  <extension point="xbmc.addon.repository" name="Kronos Kodi Addons">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/Torresmi9294/kodi-addons/main/zips/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/Torresmi9294/kodi-addons/main/zips/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/Torresmi9294/kodi-addons/main/zips</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Kronos's personal Kodi addon repository</summary>
    <description lang="en_GB">Repository for testing and distributing custom Kodi addons pushed from GitHub.</description>
    <platform>all</platform>
  </extension>
</addon>
<addon id="skin.xperience1080" version="10.1.0" name="Xperience1080" provider-name="xhaggi">
    <requires>
        <import addon="xbmc.gui" version="5.17.0" />
        <import addon="script.globalsearch" version="9.0.7" />
        <import addon="script.favourites" version="8.1.2" />
        <import addon="script.artistslideshow" version="3.3.6" />
        <import addon="script.toolbox" version="2.0.0" />
        <import addon="resource.images.studios.white" version="0.0.30"/>
        <import addon="resource.images.musicgenreicons.grey" version="0.0.6"/>
        <import addon="resource.images.weatherfanart.multi" version="0.0.6"/>
    </requires>
    <extension point="xbmc.gui.skin" effectslowdown="0.80" debugging="false">
        <res width="1920" height="1080" aspect="16:9" default="true" folder="1080i" />
